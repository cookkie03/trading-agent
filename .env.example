# =====================================================================
# .env — SECRETS ONLY (API keys & connection strings).
# All tunable PARAMETERS live in config.toml (models, broker, risk, ...).
# =====================================================================

# --- LLM provider keys (default provider is OpenRouter) ---
OPENROUTER_API_KEY=
# others, only if you switch provider in config.toml [llm]:
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=

# --- Broker (Alpaca) — required when config.toml [broker] provider = "alpaca" ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- Market data ---
# FRED (macro). Free key: fred.stlouisfed.org -> My Account -> API Keys.
# Without it the Market desk simply runs without macro.
FRED_API_KEY=
# News (yfinance) and social sentiment (StockTwits) need no key.

# --- Observability (LangSmith tracing for LangGraph) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=trading-agent

# --- Database connection (contains credentials -> kept here, not in config.toml) ---
# Unset -> local SQLite at ~/.tradingagents/trading_agent.db (zero setup).
# Point at PostgreSQL/TimescaleDB for production.
#TRADINGAGENTS_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/trading_agent

# Optional: use a config file elsewhere (default: ./config.toml)
#TRADINGAGENTS_CONFIG=/path/to/config.toml
